---
// BaseLayout.astro
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "TreeBloom | Software and Media for Education",
	description = "TreeBloom provides software and media for education, built for clarity and scale.",
} = Astro.props;

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />
	</head>
	<body>
		<header>
			<a href="/" class="brand">
				<div class="brand-text">
					<h1>TreeBloom</h1>
					<p>Software and Media for Education</p>
				</div>
			</a>
			<button class="menu-btn" id="menu-btn">&#9776;</button>
		</header>

		<div id="overlay" class="overlay"></div>
		<div id="sidebar" class="sidebar">
			<div class="sidebar-header">
				<button class="close-btn" id="close-btn">&times;</button>
			</div>
			<div class="sidebar-content">
				<a href="/" class={currentPath === "/" ? "active" : ""}>Home</a>
				<a
					href="/apps"
					class={currentPath.startsWith("/apps") ? "active" : ""}
					>Apps</a
				>
				<a
					href="/media"
					class={currentPath === "/media" ? "active" : ""}>Media</a
				>
				<a
					href="/contact"
					class={currentPath === "/contact" ? "active" : ""}
					>Contact</a
				>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<footer>
			&copy; {new Date().getFullYear()} Bert Jerred. All rights reserved.
		</footer>

		<script>
			function toggleMenu() {
				document.getElementById("sidebar")?.classList.toggle("open");
				document.getElementById("overlay")?.classList.toggle("open");
			}

			document
				.getElementById("menu-btn")
				?.addEventListener("click", toggleMenu);
			document
				.getElementById("close-btn")
				?.addEventListener("click", toggleMenu);
			document
				.getElementById("overlay")
				?.addEventListener("click", toggleMenu);

			// Handle Astro transitions
			document.addEventListener("astro:after-swap", () => {
				document
					.getElementById("menu-btn")
					?.addEventListener("click", toggleMenu);
				document
					.getElementById("close-btn")
					?.addEventListener("click", toggleMenu);
				document
					.getElementById("overlay")
					?.addEventListener("click", toggleMenu);
			});
		</script>
	</body>
</html>
