---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Apps | TreeBloom">
	<section>
		<h2>Our Software and Media</h2>
		<p>
			Explore our collection of resources designed for education.
			Each product is built with a focus on simplicity and
			scalability.
		</p>

		<div style="margin-top: 2rem; display: grid; gap: 1.5rem;">
			<section
				style="background: rgba(var(--primary-glow), 0.05); border-left: 4px solid var(--primary); padding: 1.5rem; border-radius: 0.5rem;"
			>
				<h3>Rubric Maker</h3>
				<p>
					Create clear, consistent, and pedagogically sound rubrics.
				</p>
				<a
					href="/apps/rubric-maker"
					style="display: inline-block; margin-top: 1rem;"
					>Rubric Maker &rarr;</a
				>
			</section>
		</div>
	</section>
</BaseLayout>
